# Seguridad del proyecto:
# evita ejecutar scripts automaticos al instalar dependencias
ignore-scripts=true

# Seguridad adicional:
# activa auditoria de vulnerabilidades durante la instalacion
audit=true
audit-level=high

# Consistencia de versiones:
# guarda versiones exactas para reducir cambios inesperados
save-exact=true

# Aislamiento de cache local:
# evita mezclar cache global del sistema
cache=.npm-cache
