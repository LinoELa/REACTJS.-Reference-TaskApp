{
  "name": "taskapp-reference",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "prop-types": "15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "5.6.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "env-cmd": "^10.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:learning": "env-cmd -f .env.learning react-scripts start",
    "start:project": "env-cmd -f .env.project react-scripts start",
    "start:both": "concurrently \"npm run start:learning\" \"npm run start:project\"",
    "build": "react-scripts build",
    "build:learning": "env-cmd -f .env.learning react-scripts build",
    "build:project": "env-cmd -f .env.project react-scripts build",
    "test": "react-scripts test",
    "test:watch": "react-scripts test --watchAll",
    "eject": "react-scripts eject",
    "safe-build": "npm run build && echo '✓ Build completado sin archivos .env'",
    "safe-deploy": "if test -f .env.local; then echo '✗ ERROR: .env.local encontrado'; exit 1; else npm run safe-build; fi",
    "ignore": "git check-ignore -v $(git ls-files --others --exclude-standard)"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
